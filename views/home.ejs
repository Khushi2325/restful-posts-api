<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PathlyLab - Share Your Thoughts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .hero-section {
            background: linear-gradient(135deg, #d13639 0%, #ff6b6b 100%);
            color: white;
            padding: 100px 0;
            text-align: center;
        }
        .hero-section h1 {
            font-size: 3.5rem;
            font-weight: bold;
            margin-bottom: 20px;
            color: white;
        }
        .hero-section p {
            font-size: 1.3rem;
            margin-bottom: 30px;
            opacity: 0.95;
        }
        .feature-card {
            padding: 30px;
            text-align: center;
            border-radius: 10px;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin: 20px 0;
            transition: transform 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .feature-icon {
            font-size: 3rem;
            margin-bottom: 20px;
        }
        .feature-card h3 {
            color: #d13639;
            margin-bottom: 15px;
        }
        .btn-primary-custom {
            background: white;
            color: #d13639;
            border: 3px solid white;
            padding: 15px 50px;
            font-size: 1.2rem;
            border-radius: 30px;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
            text-decoration: none;
        }
        .btn-primary-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            background: #f8f9fa;
            color: #d13639;
        }
        .btn-outline-custom {
            border: 3px solid white;
            color: white;
            padding: 15px 50px;
            font-size: 1.2rem;
            border-radius: 30px;
            font-weight: 700;
            background: transparent;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }
        .btn-outline-custom:hover {
            background: white;
            color: #d13639;
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .footer {
            background: #2c3e50;
            color: white;
            padding: 40px 0 20px 0;
            margin-top: 60px;
        }
        .footer h5 {
            color: #d13639;
            font-weight: bold;
            margin-bottom: 20px;
        }
        .social-links a {
            display: inline-block;
            width: 45px;
            height: 45px;
            background: #34495e;
            border-radius: 50%;
            text-align: center;
            line-height: 45px;
            margin: 0 8px;
            color: white;
            font-size: 1.3rem;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        .social-links a:hover {
            background: #d13639;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(209, 54, 57, 0.4);
        }
        .footer p {
            color: #bdc3c7;
            margin: 5px 0;
        }
        .footer-bottom {
            border-top: 1px solid #34495e;
            margin-top: 30px;
            padding-top: 20px;
            text-align: center;
            color: #95a5a6;
        }
    </style>
</head>
<body>
    <!-- Sticky Navbar -->
    <nav class="navbar navbar-expand-lg bg-body-tertiary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">PathlyLab</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-link" href="/posts">All Posts</a>
                    <a class="nav-link" href="/posts/new">Create New Post</a>
                </div>
                <div class="navbar-nav ms-auto">
                    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <span class="navbar-text me-3">
                            <strong>👤 <%= currentUser.username %></strong>
                        </span>
                        <a class="nav-link" href="/logout">Logout</a>
                    <% } else { %>
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link" href="/register">Register</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-section">
        <div class="container">
            <h1>Welcome to PathlyLab</h1>
            <p>A beautiful platform to share your thoughts, ideas, and stories with the world</p>
            <div class="mt-4">
                <a href="/register" class="btn btn-light btn-primary-custom me-3">Get Started</a>
                <a href="/posts" class="btn-outline-custom">Explore Posts</a>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="container" style="padding: 60px 20px;">
        <h2 class="text-center mb-5" style="color: #d13639; font-size: 2.5rem;">What is PathlyLab?</h2>
        <p class="text-center mb-5" style="font-size: 1.2rem; color: #555; max-width: 800px; margin: 0 auto;">
            PathlyLab is a modern social platform where you can create, share, and manage your posts effortlessly. 
            Express yourself, connect with others, and keep track of your thoughts in one beautiful place.
        </p>

        <div class="row mt-5">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">✍️</div>
                    <h3>Create Posts</h3>
                    <p>Share your thoughts and ideas with a simple and intuitive posting interface. Express yourself freely!</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">📝</div>
                    <h3>Edit Anytime</h3>
                    <p>Made a mistake? No worries! Edit your posts anytime to keep your content up-to-date and accurate.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">🗑️</div>
                    <h3>Easy Management</h3>
                    <p>Manage your posts with ease. Delete unwanted posts and keep your profile clean and organized.</p>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="feature-card">
                    <div class="feature-icon">🔐</div>
                    <h3>Secure & Private</h3>
                    <p>Your data is safe with us. Create an account and manage your posts securely with user authentication.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="feature-card">
                    <div class="feature-icon">🎨</div>
                    <h3>Beautiful Design</h3>
                    <p>Enjoy a clean, modern interface that makes posting and reading content a delightful experience.</p>
                </div>
            </div>
        </div>

        <!-- How It Works -->
        <div class="mt-5 pt-5">
            <h2 class="text-center mb-5" style="color: #d13639; font-size: 2.5rem;">How It Works</h2>
            <div class="row">
                <div class="col-md-3 text-center mb-4">
                    <div class="feature-icon">1️⃣</div>
                    <h5>Create Account</h5>
                    <p>Sign up in seconds and join our community</p>
                </div>
                <div class="col-md-3 text-center mb-4">
                    <div class="feature-icon">2️⃣</div>
                    <h5>Write Posts</h5>
                    <p>Share your thoughts and stories</p>
                </div>
                <div class="col-md-3 text-center mb-4">
                    <div class="feature-icon">3️⃣</div>
                    <h5>Manage Content</h5>
                    <p>Edit or delete posts anytime</p>
                </div>
                <div class="col-md-3 text-center mb-4">
                    <div class="feature-icon">4️⃣</div>
                    <h5>Connect</h5>
                    <p>Read and explore others' posts</p>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center mt-5 pt-5">
            <h3 style="color: #333; margin-bottom: 20px;">Ready to Share Your Story?</h3>
            <a href="/register" class="btn" style="background: linear-gradient(135deg, #d13639, #ff6b6b); color: white; padding: 15px 50px; font-size: 1.2rem; border-radius: 30px; font-weight: 700; text-decoration: none; display: inline-block; transition: all 0.3s ease;">Join PathlyLab Today</a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6 mb-4">
                    <h5>About PathlyLab</h5>
                    <p>A modern platform for sharing your thoughts, ideas, and stories with the world. Join our community today!</p>
                </div>
                <div class="col-md-6 mb-4">
                    <h5>Connect With Us</h5>
                    <p style="color: #bdc3c7;">Follow us on social media</p>
                    <div class="social-links mt-3">
                        <a href="https://www.linkedin.com/in/khushi-chorvadi-03857a28a/" target="_blank" title="LinkedIn">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                        <a href="https://www.instagram.com/pathlylabs.tech/" target="_blank" title="Instagram">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="https://github.com/Khushi2325" target="_blank" title="GitHub">
                            <i class="fab fa-github"></i>
                        </a>
                        <a href="https://x.com/Khushi4317" target="_blank" title="Twitter">
                            <i class="fa-brands fa-twitter"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 PathlyLab. All rights reserved. Made with ❤️</p>
            </div>
        </div>
    </footer>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
