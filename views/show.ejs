<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post in Detail</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .footer {
            background: #2c3e50;
            color: white;
            padding: 40px 0 20px 0;
            margin-top: 60px;
        }
        .footer h5 { color: #d13639; font-weight: bold; margin-bottom: 20px; }
        .social-links a {
            display: inline-block;
            width: 45px;
            height: 45px;
            background: #34495e;
            border-radius: 50%;
            text-align: center;
            line-height: 45px;
            margin: 0 8px;
            color: white;
            font-size: 1.3rem;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        .social-links a:hover {
            background: #d13639;
            transform: translateY(-5px);
        }
        .footer p { color: #bdc3c7; margin: 5px 0; }
        .footer-bottom {
            border-top: 1px solid #34495e;
            margin-top: 30px;
            padding-top: 20px;
            text-align: center;
            color: #95a5a6;
        }
    </style>
</head>
<body>
    <!-- Sticky Navbar -->
    <nav class="navbar navbar-expand-lg bg-body-tertiary sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">PathlyLab</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-link" href="/posts">All Posts</a>
                    <a class="nav-link" href="/posts/new">Create New Post</a>
                </div>
                <div class="navbar-nav ms-auto">
                    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <span class="navbar-text me-3">
                            <strong>👤 <%= currentUser.username %></strong>
                        </span>
                        <a class="nav-link" href="/logout">Logout</a>
                    <% } else { %>
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link" href="/register">Register</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container" style="padding: 20px;">
        <h2>Here is your post in detail</h2>
        <div class="post">
            <div class="post-header">
                <h3 class="user">@<%= post.username %></h3>
            </div>
            <h4 class="content"><%= post.content %></h4>
            <p class="post-timestamp">Posted on <span class="timestamp" data-date="<%= post.createdAt %>"></span></p>
            <% if (isOwner) { %>
                <div class="post-actions">
                    <a href="/posts/<%= post.id %>/edit" class="view-post-link">Edit Post</a>
                    <form method="POST" action="/posts/<%= post.id %>?_method=DELETE" class="inline-form">
                        <button type="submit" class="view-post-link danger-link">Delete Post</button>
                    </form>
                </div>
            <% } else { %>
                <p class="ownership-hint">Only @<%= post.username %> can edit or remove this content.</p>
            <% } %>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6 footer-section">
                    <h5>About PathlyLab</h5>
                    <p>A modern platform for sharing your thoughts, ideas, and stories with the world.</p>
                </div>
                <div class="col-md-6 footer-section">
                    <h5>Connect With Us</h5>
                    <p style="color: #bdc3c7; font-size: 0.9rem;">Follow us on social media</p>
                    <div class="social-links">
                        <a href="https://www.linkedin.com/in/khushi-chorvadi-03857a28a/" target="_blank" title="LinkedIn">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                        <a href="https://www.instagram.com/pathlylabs.tech/" target="_blank" title="Instagram">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="https://github.com/Khushi2325" target="_blank" title="GitHub">
                            <i class="fab fa-github"></i>
                        </a>
                        <a href="https://x.com/Khushi4317" target="_blank" title="Twitter">
                            <i class="fa-brands fa-twitter"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 PathlyLab. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Format timestamps in browser's local timezone
        document.querySelectorAll('.timestamp').forEach(el => {
            const dateString = el.getAttribute('data-date');
            if (dateString) {
                const date = new Date(dateString);
                const formatted = date.toLocaleString('en-US', { 
                    dateStyle: 'medium', 
                    timeStyle: 'short' 
                });
                el.textContent = formatted;
            }
        });
    </script>
</body>
</html>